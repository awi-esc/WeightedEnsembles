}

@article{befortCombinationDecadalPredictions2022,
  title = {Combination of {{Decadal Predictions}} and {{Climate Projections}} in {{Time}}: {{Challenges}} and {{Potential Solutions}}},
  shorttitle = {Combination of {{Decadal Predictions}} and {{Climate Projections}} in {{Time}}},
  author = {Befort, D. J. and Brunner, L. and Borchert, L. F. and O'Reilly, C. H. and Mignot, J. and Ballinger, A. P. and Hegerl, G. C. and Murphy, J. M. and Weisheimer, A.},
