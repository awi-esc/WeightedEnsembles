@article{harrisProbabilisticProjectionsTransient2013,
  title = {Probabilistic Projections of Transient Climate Change},
  author = {Harris, Glen R. and Sexton, David M. H. and Booth, Ben B. B. and Collins, Mat and Murphy, James M.},
  year = 2013,
  month = jun,
  journal = {Climate Dynamics},
  volume = {40},
