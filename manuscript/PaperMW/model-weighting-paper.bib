@article{liConstrainingEntireEarth2025,
  title = {Constraining the Entire {{Earth}} System Projections for More Reliable Climate Change Adaptation Planning},
  author = {Li, Chao and Zwiers, Francis W. and Zhang, Xuebin and Fischer, Erich M. and Du, Fujun and Liu, Jieyu and Wang, Jianyu and Liang, Yongxiao and Li, Tong and Yuan, Lina},
  year = 2025,
