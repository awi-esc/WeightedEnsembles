  urldate = {2025-03-24},
  abstract = {The equilibrium climate sensitivity (ECS) of the CMIP6 global circulation models (GCMs) varies from 1.83{$^\circ$}C to 5.67{$^\circ$}C. Herein, 38 GCMs are grouped into three ECS classes (low, 1.80--3.00{$^\circ$}C; medium, 3.01--4.50{$^\circ$}C; high, 4.51--6.00{$^\circ$}C) and compared against the ERA5-T2m records from 1980--1990 to 2011--2021. We found that all models with ECS {$>$} 3.0{$^\circ$}C overestimate the observed global surface warming and that spatial t-statistics rejects the data-model agreement over 60\% (using low-ECS GCMs) to 81\% (using high-ECS GCMs) of the Earth's surface. Thus, the high and medium-ECS GCMs are unfit for prediction purposes. The low-ECS GCMs are not fully satisfactory yet, but they are also found unalarming because by 2050 they predict a moderate warming ({$\Delta$}Tpreindustrial{$\rightarrow$}2050 {$\lessequivlnt$} 2{$^\circ$}C).},
  copyright = {\copyright{} 2022. The Authors.},
  langid = {english},
  keywords = {advanced statistical testing,climate change,general circulation model validation,global and local surface temperature record},
