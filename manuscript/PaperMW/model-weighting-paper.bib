  pages = {e2020EF001854},
  issn = {2328-4277},
  doi = {10.1029/2020EF001854},
  urldate = {2026-01-16},
  abstract = {Internal climate variability co-exists with anthropogenic climate change and places limits on the accuracy of regional climate projections due to its inherent unpredictability. This ``certain'' uncertainty in regional projections introduced by internal variability contrasts with uncertainty resulting from structural differences amongst climate models, which is potentially reducible as climate models improve. Initial-condition ``Large Ensembles'' of simulations with individual climate models provide a new perspective on the expected range of future climate change outcomes. Their value for climate risk assessment, adaptation management, and decision-making has yet to be fully realized.},
  copyright = {\copyright 2020. The Authors.},
  langid = {english},
  keywords = {climate change risks,climate projections,Earth System Model Large Ensembles,internal climate variability,regional climate change,uncertainty in climate change projections},
  file = {/Users/brgrus001/Zotero/storage/8Y7LXYBN/Deser - 2020 - “Certain Uncertainty The Role of Internal Climate Variability in Projections of Regional Climate Ch.pdf;/Users/brgrus001/Zotero/storage/2BISF7HG/2020EF001854.html}
}

@article{deserInsightsEarthSystem2020,
  title = {Insights from {{Earth}} System Model Initial-Condition Large Ensembles and Future Prospects},
  author = {Deser, C. and Lehner, F. and Rodgers, K. B. and Ault, T. and Delworth, T. L. and DiNezio, P. N. and Fiore, A. and Frankignoul, C. and Fyfe, J. C. and Horton, D. E. and Kay, J. E. and Knutti, R. and Lovenduski, N. S. and Marotzke, J. and McKinnon, K. A. and Minobe, S. and Randerson, J. and Screen, J. A. and Simpson, I. R. and Ting, M.},
